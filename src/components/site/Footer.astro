---
const year = new Date().getFullYear()
---

<footer class="border-t border-border/70 bg-card/60">
  <div class="mx-auto grid w-full max-w-6xl gap-8 px-4 py-10 md:grid-cols-3 md:px-6">
    <div class="space-y-2">
      <p class="text-sm font-semibold text-foreground">Astroblog</p>
      <p class="text-xs leading-relaxed text-muted-foreground">
        Ruang berbagi catatan web, frontend, dan pengalaman membangun produk digital.
      </p>
    </div>

    <div class="space-y-2">
      <p class="text-xs font-medium text-foreground">Navigasi</p>
      <div class="flex flex-col gap-1 text-xs text-muted-foreground">
        <a href="/" class="hover:text-foreground">Home</a>
        <a href="/blog" class="hover:text-foreground">Blog</a>
      </div>
    </div>

    <div class="space-y-2">
      <p class="text-xs font-medium text-foreground">Kontak</p>
      <a href="mailto:hello@example.com" class="text-xs text-muted-foreground hover:text-foreground">
        hello@example.com
      </a>
    </div>
  </div>

  <div class="border-t border-border/70 py-4 text-center text-[11px] text-muted-foreground">
    © {year} Astroblog. All rights reserved.
  </div>
</footer>
