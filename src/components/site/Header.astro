---
import ThemeToggle from "@/components/site/ThemeToggle"

const pathname = Astro.url.pathname
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
]
---

<header class="sticky top-0 z-40 border-b border-border/70 bg-background/90 backdrop-blur">
  <div class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between px-4 md:px-6">
    <a href="/" class="text-sm font-semibold tracking-tight text-foreground">cortel blog</a>

    <nav class="flex items-center gap-1 border border-border/70 bg-card p-1">
      {
        navLinks.map((link) => {
          const isActive =
            link.href === "/"
              ? pathname === "/"
              : pathname === link.href || pathname.startsWith(`${link.href}/`)

          return (
            <a
              href={link.href}
              class={`inline-flex h-8 items-center px-3 text-xs font-medium transition-colors ${
                isActive
                  ? "bg-primary text-primary-foreground"
                  : "text-muted-foreground hover:bg-muted hover:text-foreground"
              }`}
            >
              {link.label}
            </a>
          )
        })
      }
    </nav>

    <ThemeToggle client:load />
  </div>
</header>
