---
import type { BlogPostSummary } from "@/lib/sanity/types"
import PostMeta from "@/components/blog/PostMeta.astro"

interface Props {
  post: BlogPostSummary
}

const { post } = Astro.props
---

<article class="group overflow-hidden border border-border bg-card transition-colors hover:bg-muted/40">
  {
    post.coverImageUrl ? (
      <a href={`/blog/${post.slug}`} class="block aspect-video overflow-hidden border-b border-border bg-muted">
        <img
          src={post.coverImageUrl}
          alt={post.coverImageAlt || post.title}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        />
      </a>
    ) : (
      <div class="aspect-video border-b border-border bg-muted" />
    )
  }

  <div class="p-5">
    <div class="mb-3">
      <PostMeta pubDate={post.pubDate} tags={post.tags} readingMinutes={post.readingMinutes} />
    </div>

    <h2 class="text-base font-semibold tracking-tight text-foreground group-hover:text-primary">
      <a href={`/blog/${post.slug}`} class="outline-none focus-visible:ring-1 focus-visible:ring-ring">
        {post.title}
      </a>
    </h2>

    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{post.description}</p>

    <a href={`/blog/${post.slug}`} class="mt-5 inline-flex text-xs font-medium text-primary hover:underline">
      Baca selengkapnya
    </a>
  </div>
</article>
