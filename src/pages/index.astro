---
import Layout from "@/layouts/main.astro"
import PostCard from "@/components/blog/PostCard.astro"
import ContactModal from "@/components/site/ContactModal"
import { getFeaturedPosts } from "@/lib/sanity/posts"

const FEATURED_COUNT = 6
const featuredPosts = await getFeaturedPosts(FEATURED_COUNT)
---

<Layout
  title="cortel blog — Home"
  description="Blog modern berbasis Astro untuk berbagi insight frontend, UI/UX, dan web development."
>
  <section id="featured" class="mx-auto w-full max-w-6xl px-4 py-12 md:px-6 md:py-16">
    <div class="mb-6 flex items-center justify-between gap-3">
      <div>
        <p class="text-xs tracking-wide text-primary uppercase">Latest Insights</p>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight text-foreground md:text-3xl">
          Artikel terbaru cortel blog
        </h1>
      </div>
      <a href="/blog" class="text-xs font-medium text-primary hover:underline">Lihat semua</a>
    </div>

    {
      featuredPosts.length > 0 ? (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {featuredPosts.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {Array.from({ length: FEATURED_COUNT }).map(() => (
            <article class="border border-border bg-card p-5">
              <div class="h-3 w-24 animate-pulse bg-muted" />
              <div class="mt-4 h-4 w-4/5 animate-pulse bg-muted" />
              <div class="mt-2 h-4 w-3/5 animate-pulse bg-muted" />
              <div class="mt-4 h-3 w-full animate-pulse bg-muted" />
              <div class="mt-2 h-3 w-5/6 animate-pulse bg-muted" />
              <div class="mt-6 h-3 w-1/3 animate-pulse bg-muted" />
            </article>
          ))}
        </div>
      )
    }
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-12 md:px-6 md:pb-16">
    <div class="border border-border bg-card p-6 md:flex md:items-center md:justify-between md:gap-6 md:p-8">
      <div>
        <p class="text-xs tracking-wide text-primary uppercase">Collaborate</p>
        <h2 class="mt-2 text-xl font-semibold tracking-tight text-foreground">Diskusikan kebutuhan konten timmu</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          Punya topik spesifik untuk dibahas? Kirim detail kebutuhan dan tim kami akan merespons.
        </p>
      </div>
      <div class="mt-5 inline-flex md:mt-0">
        <ContactModal client:load />
      </div>
    </div>
  </section>
</Layout>
