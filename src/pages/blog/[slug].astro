---
import Layout from "@/layouts/main.astro"
import PostMeta from "@/components/blog/PostMeta.astro"
import { getPostBySlug, getPostSlugs } from "@/lib/sanity/posts"
import { portableTextToHtml } from "@/lib/sanity/portableText"

export async function getStaticPaths() {
  const slugs = await getPostSlugs()

  return slugs.map((slug) => ({
    params: { slug },
  }))
}

const { slug } = Astro.params

if (!slug) {
  throw new Error("Missing slug param")
}

const post = await getPostBySlug(slug)

if (!post) {
  return Astro.redirect("/blog")
}

const html = portableTextToHtml(post.body)
---

<Layout title={`${post.title} — Astroblog`} description={post.description}>
  <article class="mx-auto w-full max-w-3xl px-4 py-12 md:px-6 md:py-16">
    <a href="/blog" class="inline-flex text-xs text-primary hover:underline">← Kembali ke Blog</a>

    <header class="mt-4 border-b border-border/70 pb-5">
      <h1 class="text-3xl leading-tight font-semibold tracking-tight text-foreground md:text-4xl">
        {post.title}
      </h1>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{post.description}</p>
      <div class="mt-4">
        <PostMeta pubDate={post.pubDate} tags={post.tags} readingMinutes={post.readingMinutes} />
      </div>
    </header>

    <div class="prose prose-neutral dark:prose-invert mt-8 max-w-none text-sm leading-relaxed" set:html={html} />
  </article>
</Layout>
