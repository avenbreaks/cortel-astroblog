---
import Layout from "@/layouts/main.astro"
import PostMeta from "@/components/blog/PostMeta.astro"
import { getPostBySlug, getPostSlugs } from "@/lib/sanity/posts"
import { portableTextToHtml } from "@/lib/sanity/portableText"
import TweetEmbeds from "@/components/blog/TweetEmbeds"
import AgentAvatar from "@/components/smoothui/agent-avatar"

export const prerender = true

export async function getStaticPaths() {
  const slugs = await getPostSlugs()

  return slugs.map((slug) => ({
    params: { slug },
  }))
}

const { slug } = Astro.params

if (!slug) {
  throw new Error("Missing slug param")
}

const post = await getPostBySlug(slug)

if (!post) {
  return Astro.redirect("/blog")
}

const html = portableTextToHtml(post.body)
const hasMermaid = html.includes('class="mermaid')
const hasTweetEmbeds = html.includes("data-tweet-id=")
---

<Layout title={`${post.title} — cortel blog`} description={post.description}>
  <article class="mx-auto w-full max-w-3xl px-4 py-12 md:px-6 md:py-16">
    <a href="/blog" class="inline-flex text-xs font-medium text-primary hover:underline">← Kembali ke Blog</a>

    <header class="mt-5 border-b border-border/70 pb-7">
      <h1 class="text-3xl leading-tight font-semibold tracking-tight text-foreground md:text-4xl md:leading-tight">
        {post.title}
      </h1>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-muted-foreground md:text-base">{post.description}</p>
      <div class="mt-5">
        <PostMeta pubDate={post.pubDate} tags={post.tags} readingMinutes={post.readingMinutes} />
      </div>

      <div class="mt-5 flex items-center gap-3 border border-border/70 bg-card/60 p-3">
        <AgentAvatar client:load seed="cortel-admin" size={42} animated={false} className="border border-border/70" />
        <div>
          <p class="text-xs font-medium text-foreground">Posted by Admin</p>
          <p class="text-[11px] text-muted-foreground">Editorial • cortel blog</p>
        </div>
      </div>
    </header>

    <div
      class="prose prose-neutral dark:prose-invert prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-headings:text-foreground prose-p:text-foreground/95 prose-strong:text-foreground prose-code:text-foreground prose-code:before:content-none prose-code:after:content-none prose-pre:my-0 prose-pre:bg-transparent prose-img:my-0 prose-figure:my-0 mt-10 max-w-none text-base leading-8"
      set:html={html}
    />
  </article>

  {hasTweetEmbeds && <TweetEmbeds client:load />}

  {
    hasMermaid && (
      <script type="module" is:inline>
        import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"

        mermaid.initialize({
          startOnLoad: false,
          securityLevel: "strict",
          theme: "default",
        })

        mermaid.run({ querySelector: ".mermaid" })
      </script>
    )
  }
</Layout>
