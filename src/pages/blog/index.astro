---
import Layout from "@/layouts/main.astro"
import PostCard from "@/components/blog/PostCard.astro"
import { getAllPublishedPosts } from "@/lib/sanity/posts"

const posts = await getAllPublishedPosts()
const selectedTag = Astro.url.searchParams.get("tag")?.trim().toLowerCase() ?? ""
const filteredPosts = selectedTag
  ? posts.filter((post) => post.tags.some((tag) => tag.toLowerCase() === selectedTag))
  : posts
---

<Layout
  title="Blog — Astroblog"
  description="Daftar artikel terbaru tentang frontend, UI/UX, dan web development."
>
  <section class="border-b border-border/70">
    <div class="mx-auto w-full max-w-6xl px-4 py-14 md:px-6 md:py-18">
      <p class="text-xs tracking-wide text-primary uppercase">Blog</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-foreground md:text-4xl">Semua Artikel</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
        Kumpulan catatan teknis dan praktik UI/UX yang bisa langsung diterapkan.
      </p>
      {
        selectedTag && (
          <div class="mt-4 inline-flex items-center gap-2 border border-border bg-card px-3 py-1.5 text-xs text-muted-foreground">
            <span>Filter aktif: #{selectedTag}</span>
            <a href="/blog" class="text-primary hover:underline">
              Reset
            </a>
          </div>
        )
      }
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 py-10 md:px-6 md:py-14">
    {
      filteredPosts.length > 0 ? (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {filteredPosts.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <div class="border border-border bg-card p-6 text-sm text-muted-foreground">
          {selectedTag
            ? `Belum ada artikel untuk tag #${selectedTag}.`
            : "Belum ada artikel yang dipublikasikan."}
        </div>
      )
    }
  </section>
</Layout>
